# Скелет работает целиком в памяти — все переменные опциональны.
APP_ENV=local
SESSION_COOKIE_NAME=vca_session
SESSION_TTL_DAYS=30
ISSUE_RESULT_TTL_MINUTES=15
CORS_ORIGINS=http://localhost:5173
FIRST_ADMIN_LOGIN=midhey
# Если не задать — пароль сгенерируется и попадёт в лог при первом старте.
FIRST_ADMIN_PASSWORD=
# fake — встроенная имитация Go-агента; http — реальные запросы к узлам.
AGENT_MODE=fake
SETUP_WORKER_ENABLED=true
# Задержка между шагами имитации установки VPS (для демонстрации статусов в UI).
SETUP_STEP_DELAY_SECONDS=1.2
# CSRF/secure-куки включаются автоматически при APP_ENV != local; можно форсировать:
# CSRF_ENABLED=true
# COOKIE_SECURE=true

# Понадобятся при подключении БД и прода (пока не используются):
# DATABASE_URL=postgresql+asyncpg://...
# APP_SECRET_KEY=...
# ENCRYPTION_KEY=...
# SETUP_DEPLOY_SCRIPT_PATH=../agent/scripts/deploy-agent.sh
# SETUP_BACKEND_ALLOW_IP=...
# SETUP_AGENT_LISTEN=0.0.0.0:8090
