APP_ENV=local
SESSION_COOKIE_NAME=vca_session
SESSION_TTL_DAYS=30
ISSUE_RESULT_TTL_MINUTES=15
CORS_ORIGINS=http://localhost:5173

# БД можно задать одной готовой ссылкой:
# DATABASE_URL=postgresql://vpn_user:change-me@127.0.0.1:5432/vpn_control
#
# Или раздельно: backend сам соберёт DATABASE_URL.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=vpn_control
DB_USER=vpn_user
DB_PASSWORD=change-me
DB_SSLMODE=require

FIRST_ADMIN_LOGIN=midhey
# Если не задать — пароль сгенерируется и попадёт в лог при первом старте.
FIRST_ADMIN_PASSWORD=
# fake — встроенная имитация Go-агента; http — реальные запросы к узлам.
# Вне APP_ENV=local допустим только http.
AGENT_MODE=fake
# Fernet key. Обязателен вне local: `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
# ENCRYPTION_KEY=
SETUP_WORKER_ENABLED=true
# Нужна только для stub runner в local demo.
SETUP_STEP_DELAY_SECONDS=1.2
# CSRF/secure-куки включаются автоматически при APP_ENV != local; можно форсировать:
# CSRF_ENABLED=true
# COOKIE_SECURE=true

# Production: обязательны APP_ENV!=local, AGENT_MODE=http, ENCRYPTION_KEY,
# SETUP_RUNNER=deploy_script и узкий список IP/CIDR backend-а.
# SETUP_RUNNER=stub
# SETUP_DEPLOY_SCRIPT_PATH=../agent/scripts/deploy-agent.sh
# SETUP_AGENT_LISTEN=10.0.0.10:8090
# SETUP_AGENT_BASE_URL_TEMPLATE=http://{host}:8090
# SETUP_AGENT_ALLOW_IPS=10.0.0.5
# SETUP_TIMEOUT_SECONDS=600
# SETUP_ALLOW_PUBLIC_AGENT_ACCESS=false
