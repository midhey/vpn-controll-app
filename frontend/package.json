{
  "name": "podsos-vpn-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "npm run assets && vite --host localhost --port 5173",
    "build": "npm run assets && npm run typecheck && vite build",
    "preview": "vite preview --host localhost --port 4173",
    "assets": "npm run assets:fonts && npm run assets:images",
    "assets:fonts": "node tools/fonts.mjs",
    "assets:images": "node tools/images.mjs",
    "lint": "npm run lint:js && npm run lint:styles",
    "lint:js": "oxlint",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "check:tokens": "node tools/check-tokens.mjs",
    "test": "node --test",
    "typecheck": "vue-tsc --noEmit && tsc --noEmit --project tsconfig.node.json",
    "check": "npm run lint && npm run check:tokens && npm test && npm run typecheck"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "vue": "^3.5.39",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "fonteditor-core": "^2.6.3",
    "oxlint": "^1.42.0",
    "postcss": "^8.5.16",
    "postcss-scss": "^4.0.9",
    "sass": "^1.101.0",
    "sharp": "^0.35.3",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.0.0",
    "vue-tsc": "^3.3.7"
  }
}
